{
  "name": "resqmesh-server",
  "version": "1.0.0",
  "description": "ResQMesh Node.js/Express backend — IoT ingress & real-time WebSocket relay",
  "main": "dist/server.js",
  "scripts": {
    "predev": "kill-port 5000 || true",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "keywords": [
    "resqmesh",
    "iot",
    "express",
    "socket.io",
    "disaster-response"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}